        }
      ],
      "uuid": "f1e07287-7885-40d8-87a0-4ded14408363"
    },
    {
      "start_time": 364,
      "end_time": 370,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "SILENCE THE EYES! BECALM THE SENSES!"
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "text": "\n"
            }
          ]
        }
      ],

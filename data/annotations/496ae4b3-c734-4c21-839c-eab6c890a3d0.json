    {
      "start_time": 7,
      "end_time": 23,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "This will be a poetry reading by Michael McClure and Allen Ginsberg from Naropa Institute’s Jack Kerouac School of Disembodied Poetics, June 16, 1976. "
            }
          ]
        }
      ],
      "tags": [
        {
